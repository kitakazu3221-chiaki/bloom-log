# ── Bloom Log 環境変数 ──────────────────────────────
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# JWT署名キー（必ず変更してください）
JWT_SECRET=your-random-secret-here-change-me

# サーバーポート（デフォルト: 3001）
PORT=3001

# Node環境（production / development）
NODE_ENV=production

# Stripe（サブスクリプション決済）
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_JPY=price_...
STRIPE_PRICE_ID_USD=price_...
